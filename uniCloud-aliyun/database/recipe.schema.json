{
  "bsonType": "object",
  "required": ["_id", "authorId", "name", "createTime"],
  "properties": {
    "_id": {
      "description": "菜谱ID"
    },
    "authorId": {
      "bsonType": "string",
      "description": "作者openid"
    },
    "authorInfo": {
      "bsonType": "object",
      "description": "作者信息快照",
      "properties": {
        "nickname": { "bsonType": "string" },
        "avatar": { "bsonType": "string" }
      }
    },
    "name": {
      "bsonType": "string",
      "description": "菜名"
    },
    "coverImage": {
      "bsonType": "string",
      "description": "封面图URL"
    },
    "description": {
      "bsonType": "string",
      "description": "简介"
    },
    "cuisine": {
      "bsonType": "string",
      "description": "菜式：中式/日式/西式/韩式"
    },
    "difficulty": {
      "bsonType": "string",
      "description": "难度：简单/中等/困难"
    },
    "cookTime": {
      "bsonType": "string",
      "description": "烹饪时间"
    },
    "servings": {
      "bsonType": "number",
      "description": "份数"
    },
    "ingredients": {
      "bsonType": "array",
      "description": "食材列表",
      "items": {
        "bsonType": "object",
        "properties": {
          "name": { "bsonType": "string" },
          "amount": { "bsonType": "string" }
        }
      }
    },
    "steps": {
      "bsonType": "array",
      "description": "步骤",
      "items": {
        "bsonType": "object",
        "properties": {
          "order": { "bsonType": "number" },
          "content": { "bsonType": "string" },
          "image": { "bsonType": "string" }
        }
      }
    },
    "tips": {
      "bsonType": "string",
      "description": "小贴士"
    },
    "tags": {
      "bsonType": "array",
      "description": "标签",
      "items": { "bsonType": "string" }
    },
    "mood": {
      "bsonType": "string",
      "description": "适合心情"
    },
    "stats": {
      "bsonType": "object",
      "description": "统计数据",
      "properties": {
        "views": { "bsonType": "number", "description": "浏览量" },
        "likes": { "bsonType": "number", "description": "点赞数" },
        "favorites": { "bsonType": "number", "description": "收藏数" },
        "comments": { "bsonType": "number", "description": "评论数" }
      }
    },
    "status": {
      "bsonType": "string",
      "description": "状态：pending/approved/rejected",
      "enum": ["pending", "approved", "rejected"]
    },
    "isFeatured": {
      "bsonType": "bool",
      "description": "是否精选"
    },
    "createTime": {
      "bsonType": "string",
      "description": "创建时间"
    },
    "updateTime": {
      "bsonType": "string",
      "description": "更新时间"
    }
  }
}
