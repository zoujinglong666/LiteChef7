{
  "bsonType": "object",
  "required": ["_id", "recipeId", "userId", "content", "createTime"],
  "properties": {
    "_id": { "description": "评论ID" },
    "recipeId": {
      "bsonType": "string",
      "description": "菜谱ID"
    },
    "userId": {
      "bsonType": "string",
      "description": "评论者openid"
    },
    "userInfo": {
      "bsonType": "object",
      "properties": {
        "nickname": { "bsonType": "string" },
        "avatar": { "bsonType": "string" }
      }
    },
    "content": {
      "bsonType": "string",
      "description": "评论内容"
    },
    "likeCount": {
      "bsonType": "number",
      "description": "点赞数"
    },
    "replyTo": {
      "bsonType": "string",
      "description": "回复的评论ID"
    },
    "createTime": {
      "bsonType": "string"
    }
  }
}
