{
  "bsonType": "object",
  "required": ["_id", "authorId", "content", "createTime"],
  "properties": {
    "_id": { "description": "动态ID" },
    "authorId": { "bsonType": "string", "description": "作者openid" },
    "authorInfo": {
      "bsonType": "object",
      "properties": {
        "nickname": { "bsonType": "string" },
        "avatar": { "bsonType": "string" }
      }
    },
    "content": { "bsonType": "string", "description": "文字内容" },
    "images": {
      "bsonType": "array",
      "description": "图片URL列表",
      "items": { "bsonType": "string" }
    },
    "recipeId": { "bsonType": "string", "description": "关联菜谱ID" },
    "recipeInfo": {
      "bsonType": "object",
      "description": "关联菜谱快照",
      "properties": {
        "name": { "bsonType": "string" },
        "coverImage": { "bsonType": "string" }
      }
    },
    "type": {
      "bsonType": "string",
      "description": "类型：share/wish/cook",
      "enum": ["share", "wish", "cook"]
    },
    "stats": {
      "bsonType": "object",
      "properties": {
        "likes": { "bsonType": "number" },
        "comments": { "bsonType": "number" }
      }
    },
    "isWish": { "bsonType": "bool", "description": "是否是许愿" },
    "wishFulfilled": { "bsonType": "bool", "description": "许愿是否被实现" },
    "createTime": { "bsonType": "string" }
  }
}
